{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mythos",
  "version": "0.1.0",
  "identifier": "com.rpgforge.mythos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mythos",
        "width": 1440,
        "height": 900,
        "minWidth": 820,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' https://api.anthropic.com https://api.openai.com http://localhost:11434; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "AI-native worldbuilding writer's app",
    "longDescription": "Mythos is an AI-native writer's app for novelists and worldbuilders — manuscript editor, codex, timeline, atlas, story weaver, and a Muse AI assistant.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {}
}
