<!DOCTYPE gui SYSTEM "kpartgui.dtd">
<gui name="rpgforge" version="3">
  <MenuBar>
    <Menu name="file">
      <text>&amp;File</text>
      <Action name="file_new"/>
      <Action name="file_open"/>
      <Separator/>
      <Action name="project_new"/>
      <Action name="project_open"/>
      <Action name="project_close"/>
      <Separator/>
      <Action name="file_save"/>
      <Action name="file_save_as"/>
      <Separator/>
      <Action name="project_settings"/>
      <Separator/>
      <Action name="compile_project"/>
      <Separator/>
      <Action name="file_quit"/>
    </Menu>
    <!-- Edit, View, Selection, and Tools menus are provided by
         KTextEditor::View's merged GUI client -->
    <Menu name="view">
      <Action name="toggle_preview"/>
    </Menu>
    <Menu name="ai">
      <text>&amp;AI Assistant</text>
      <Action name="ai_expand"/>
      <Action name="ai_rewrite"/>
      <Action name="ai_summarize"/>
    </Menu>
    <Menu name="settings">
      <text>&amp;Settings</text>
      <Action name="project_settings"/>
      <Separator/>
      <Action name="global_settings"/>
    </Menu>
    <!-- Remove the empty Search menu that KTextEditor creates -->
    <Menu name="search" deleted="true"/>
  </MenuBar>
  <ToolBar name="mainToolBar">
    <text>Main Toolbar</text>
    <Action name="file_new"/>
    <Action name="file_open"/>
    <Action name="file_save"/>
    <Separator/>
    <Action name="project_open"/>
    <Action name="compile_project"/>
    <Separator/>
    <Action name="toggle_preview"/>
  </ToolBar>
</gui>
